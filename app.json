{
  "expo": {
    "name": "Pitch",
    "slug": "pitch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pitch",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E4820"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pitch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to record pitch videos.",
        "NSMicrophoneUsageDescription": "Used to record pitch videos.",
        "NSPhotoLibraryUsageDescription": "Used to upload pitch videos and profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E4820"
      },
      "package": "com.pitch.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6DB882"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Pitch to access your photos for pitch videos.",
          "cameraPermission": "Allow Pitch to use your camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
